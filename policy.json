{
  "roles": {
    "member": ["view", "post"],
    "moderator": ["view", "post", "moderate"],
    "admin": ["view", "post", "moderate"]
  },
  "collections": {
    "user": {
      "read": "view",
      "write": "post",
      "scope": [
        { "filter": "oidc_sub = $jwt.custom.oidc_sub", "applies_to": "write", "unless_privilege": "moderate" }
      ]
    },
    "room": {
      "read": "view",
      "write": "post",
      "scope": [
        { "filter": "created_by = $jwt.sub", "applies_to": "write", "unless_privilege": "moderate" }
      ]
    },
    "message": {
      "read": "view",
      "write": "post",
      "scope": [
        { "filter": "user = $jwt.sub OR collaborative = true", "applies_to": "write", "unless_privilege": "moderate" }
      ]
    },
    "userroles": {
      "read": "view",
      "write": "system"
    },
    "ban": {
      "read": "view",
      "write": "moderate",
      "scope": [
        { "filter": "user = $jwt.sub", "applies_to": "read", "unless_privilege": "moderate" }
      ]
    },
    "reaction": {
      "read": "view",
      "write": "post",
      "scope": [
        { "filter": "user = $jwt.sub", "applies_to": "write" }
      ]
    },
    "readstate": {
      "read": "view",
      "write": "post",
      "scope": [
        { "filter": "user = $jwt.sub" }
      ]
    },
    "modaction": {
      "read": "view",
      "write": "moderate"
    }
  }
}
